generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Batch {
  id            String     @id @default(cuid())
  createdAt     DateTime   @default(now())
  fileName      String
  totalInput    Int
  totalOutput   Int
  duplicates    Int
  changes       Int
  qualityBefore Float?     // Score de calidad del dataset antes de normalizar (0-100)
  qualityAfter  Float?     // Score de calidad del dataset despues de normalizar (0-100)
  comunas       Comuna[]
  logs          LogEntry[]

  // A-06: índice para ordenar y filtrar por fecha de creación en analytics y historial
  @@index([createdAt])
}

model Comuna {
  id         String   @id @default(cuid())
  original   String
  normalized String
  batchId    String
  batch      Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model LogEntry {
  id         String   @id @default(cuid())
  batchId    String
  batch      Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  lineNumber Int
  original   String
  normalized String
  changeType String
  detail     String?
  createdAt  DateTime @default(now())

  // A-06: índice para filtrar logs por batch (consultas en DataTable y LogViewer)
  @@index([batchId])
}

// ── Módulo Famosos ──────────────────────────────────────────────────────────

/// Encabezado de cada procesamiento del archivo de famosos.
/// Almacena estadísticas globales del batch.
model FamosoBatch {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  fileName    String
  totalInput  Int      // Líneas totales en el archivo original
  totalOutput Int      // Famosos únicos guardados tras deduplicar
  duplicates  Int      // Cantidad de duplicados eliminados
  cumpleanos  Int      // Cuántos famosos cumplen años hoy
  famosos     Famoso[]

  // A-06: índice para ordenar por fecha en analytics e historial de famosos
  @@index([createdAt])
}

/// Un personaje famoso procesado y normalizado.
/// La fecha de nacimiento se almacena en múltiples formatos según disponibilidad.
model Famoso {
  id               String      @id @default(cuid())
  batchId          String
  batch            FamosoBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  nombre           String      // Nombre completo del personaje
  fechaOriginal    String      // Fecha tal como venía en el archivo fuente
  fechaNormalizada String?     // Fecha estandarizada DD-MM-YYYY (null si es aproximada)
  fechaAprox       String?     // Texto libre para fechas históricas: "aprox. 69 a.C."
  edad             Int?        // Edad calculada al día de hoy (null si la fecha es aproximada)
  esCumpleanos     Boolean     @default(false) // True si hoy coincide con su día y mes de nacimiento
  createdAt        DateTime    @default(now())

  @@index([batchId])
}

// ── Módulo Lugares ──────────────────────────────────────────────────────────

/// Encabezado de cada procesamiento del archivo de lugares turísticos.
model LugarBatch {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  fileName    String
  totalInput  Int      // Registros totales en el archivo (sin contar header)
  totalOutput Int      // Lugares únicos guardados tras deduplicar
  duplicates  Int      // Duplicados eliminados (mismo nombre + misma georef)
  lugares     Lugar[]

  // A-06: índice para ordenar por fecha en analytics e historial de lugares
  @@index([createdAt])
}

/// Un lugar turístico único con sus datos relacionados.
/// Se considera duplicado solo si coinciden nombre Y coordenadas (ejemplo: Apple Park aparece 2 veces con coords distintas → ambos son válidos).
model Lugar {
  id        String         @id @default(cuid())
  batchId   String
  batch     LugarBatch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  nombre    String         // Nombre del lugar tal como aparece en el archivo
  georef    Georeferencia? // Coordenadas geográficas (relación 1:1 opcional)
  direccion Direccion?     // Dirección postal estructurada (relación 1:1 opcional)
  createdAt DateTime       @default(now())

  @@index([batchId])
}

/// Coordenadas geográficas de un lugar (latitud y longitud).
/// Relación 1:1 con Lugar.
model Georeferencia {
  id       String @id @default(cuid())
  lugarId  String @unique
  lugar    Lugar  @relation(fields: [lugarId], references: [id], onDelete: Cascade)
  latitud  Float  // Latitud en grados decimales (ej: -33.4489)
  longitud Float  // Longitud en grados decimales (ej: -70.6693)
}

/// Dirección postal de un lugar, parseada en componentes estructurados.
/// Relación 1:1 con Lugar.
model Direccion {
  id                    String  @id @default(cuid())
  lugarId               String  @unique
  lugar                 Lugar   @relation(fields: [lugarId], references: [id], onDelete: Cascade)
  nombreCalle           String? // Nombre de la calle o vía (sin número)
  numeroCalle           String? // Número de la dirección
  ciudadEstadoProvincia String? // Ciudad, estado o provincia
  pais                  String? // País del lugar
  rawDireccion          String  // Dirección original sin parsear (respaldo completo)
}
